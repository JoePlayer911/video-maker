import os
import numpy as np
import cv2
import json
import sys
import io
from contextlib import contextmanager
from scipy.spatial import ConvexHull
from types import SimpleNamespace
from pathlib import Path
from PIL import Image
import torch
import insightface
import gc
import shutil
from imutils import face_utils
from pyannote.audio import Pipeline
from scripts.utils.video import Video
from scenedetect import detect, ContentDetector
from copy import deepcopy
from scripts.utils.logger import Logger


@contextmanager
def suppress_stdout():
    stdout_original = sys.stdout
    stderr_original = sys.stderr
    sys.stdout = sys.stderr = io.StringIO()
    sys.stdout = io.StringIO()
    try:
        yield
    finally:
        sys.stdout = stdout_original
        sys.stderr = stderr_original


class Analyse:
    def __init__(self, project_name, video, resize_factror, face_swap, only_mouth, minimum_face_size, keyframes_on_speakers, keyframe_on_scenes):
        self.wav2lip_studio = os.path.sep.join(os.path.abspath(__file__).split(os.path.sep)[:-3])
        self.wav2lip_scripts = os.path.sep.join(os.path.abspath(__file__).split(os.path.sep)[:-2])
        self.projects_folder = os.path.join(self.wav2lip_studio, "projects")
        self.model_folder = os.path.join(self.wav2lip_studio, 'models')
        self.project_name = project_name
        self.project_folder = os.path.join(self.projects_folder, project_name)
        self.analyse_folder = os.path.join(self.project_folder, "analyse")
        self.debug_folder = os.path.join(self.project_folder, "debug")
        self.input_video = os.path.join(self.project_folder, "input")
        self.faceswap_video_folder = os.path.join(self.project_folder, "faceswap")
        self.wav2lip_video_folder = os.path.join(self.project_folder, "wav2lip")
        self.audio_folder = os.path.join(self.project_folder, "audio")
        self.temp_folder = os.path.join(self.project_folder, "temp")
        self.video = video
        self.resize_factor = resize_factror
        self.face_swap = face_swap
        self._only_mouth = only_mouth
        self.mouth_mask_dilatation = 15
        self.erode_face_mask = 15
        self.mask_blur = 15
        self.pad = [0, 0, 0, 0]
        self.source_faces = None
        self.device = 'cuda' if torch.cuda.is_available() else 'cpu'
        self.minimum_face_size = minimum_face_size
        self.keyframes_on_speakers = keyframes_on_speakers
        self.keyframes_on_scenes = keyframe_on_scenes
        self.face_analyser = None
        self.logger = Logger()
        self.keyframes = []
        self.frames = {}
        self.huggingface_token = json.load(open(self.wav2lip_studio + "/api_keys.json", "r"))["huggingface_token"]

    @property
    def only_mouth(self):
        return self._only_mouth

    @only_mouth.setter
    def only_mouth(self, value):
        self._only_mouth = value

    def init_models(self):
        self.logger.info("{0}{1}", 'Loading insigth Model', "")
        with suppress_stdout():
            self.face_analyser = insightface.app.FaceAnalysis(name="buffalo_l",
                                                              providers=["CUDAExecutionProvider", "CPUExecutionProvider"])
            self.face_analyser.prepare(ctx_id=0, det_size=(640, 640))

    def create_project(self):
        self.logger.info("{0}{1}", 'Create project ', self.project_name)
        if not os.path.exists(self.project_folder):
            os.makedirs(self.project_folder)
        if not os.path.exists(self.analyse_folder):
            os.makedirs(self.analyse_folder)
        if not os.path.exists(self.debug_folder):
            os.makedirs(self.debug_folder)
        if not os.path.exists(self.faceswap_video_folder):
            os.makedirs(self.faceswap_video_folder)
        if not os.path.exists(self.wav2lip_video_folder):
            os.makedirs(self.wav2lip_video_folder)
        if not os.path.exists(self.audio_folder):
            os.makedirs(self.audio_folder)
        if not os.path.exists(self.input_video):
            os.makedirs(self.input_video)
        if not os.path.exists(self.temp_folder):
            os.makedirs(self.temp_folder)

    def check_project(self):
        existing_projects = os.path.exists(self.project_folder)
        self.logger.info("{0}{1}", 'Project ever exists: ', existing_projects)
        return existing_projects

    def load_projects(self):
        # iterer dans le répertoire "projects" et trouver tous répertoirs
        self.logger.info("{0}{1}", 'Loading available projects: ', "")
        projects = []
        for project in os.listdir(self.projects_folder):
            if os.path.isdir(os.path.join(self.projects_folder, project)):
                projects.append(project)

        voices = sorted([voice.name for voice in Path(f"{self.wav2lip_scripts}/tts/voices").glob("*.wav")])

        return projects, voices

    def get_all_face(self, img_path: str, det_size=(640, 640)):
        if type(img_path) == str:
            target = Image.open(img_path)
            img_data = cv2.cvtColor(np.array(target), cv2.COLOR_RGB2BGR)
        else:
            img_data = cv2.cvtColor(np.array(img_path), cv2.COLOR_RGB2BGR)
        face = self.face_analyser.get(img_data)
        face = sorted(face, key=lambda x: x.bbox[0])

        indices_to_remove = []

        for x, f in enumerate(face):

            left_corner_of_mouth = (f.landmark_3d_68[48][0]-f.bbox[0], f.landmark_3d_68[48][1]-f.bbox[1])
            right_corner_of_mouth = (f.landmark_3d_68[54][0]-f.bbox[0], f.landmark_3d_68[54][1]-f.bbox[1])

            angle = np.arctan2(right_corner_of_mouth[1] - left_corner_of_mouth[1],
                               right_corner_of_mouth[0] - left_corner_of_mouth[0])
            angle = np.degrees(angle)
            # center calculate on the middle of the mouth
            center = (int((f.bbox[0] + left_corner_of_mouth[0] + f.bbox[0] + right_corner_of_mouth[0]) / 2),
                      int((f.bbox[1] + left_corner_of_mouth[1] + f.bbox[1] + right_corner_of_mouth[1]) / 2))

            f.center = center
            f.angle = angle
            f.bbox[f.bbox < 0] = 0
            f.bbox = f.bbox.astype(int)
            if f.bbox[2] - f.bbox[0] < self.minimum_face_size:
                indices_to_remove.append(x)

        # Supprimez les éléments en parcourant la liste des indices à l'envers
        for index in reversed(indices_to_remove):
            face.pop(index)
        try:
            return face
        except IndexError:
            return None

    @staticmethod
    def draw_faces(img, faces, faces_properties, face_only):
        for i, face in enumerate(faces):
            pady1, pady2, padx1, padx2 = 0, 0, 0, 0
            if faces_properties:
                pady1, pady2, padx1, padx2 = faces_properties[i]["padding"]
            bbox = face.bbox.astype(int)
            y1 = int(max(0, bbox[1] - pady1))
            y2 = int(min(img.shape[0], bbox[3] + pady2))
            x1 = int(max(0, bbox[0] - padx1))
            x2 = int(min(img.shape[1], bbox[2] + padx2))

            # crop face and save
            cv2.rectangle(img, (x1, y1), (x2, y2), (0, 255, 0), 2)
            if face_only:
                cv2.putText(img, f"face id: {i}", (bbox[0]+20, bbox[1]+20),
                            cv2.FONT_HERSHEY_SIMPLEX, 1, (0, 255, 0), 3)
                cv2.putText(img, f"{bbox[2] - bbox[0]} px", (bbox[0], bbox[3]),
                            cv2.FONT_HERSHEY_SIMPLEX, 1, (0, 0, 255), 7)
            else:
                cv2.putText(img, f"face id: {i}", (bbox[0] - 10, bbox[1] - 10),
                            cv2.FONT_HERSHEY_SIMPLEX, 2, (0, 255, 0), 3)
                cv2.putText(img, f"{bbox[2]-bbox[0]} px", (bbox[0] + 10, bbox[3] + 40),
                            cv2.FONT_HERSHEY_SIMPLEX, 2, (0, 0, 255), 7)


    @staticmethod
    def dilate_mouth(mouth, w, h, mouth_mask_dilatation):
        mask = np.zeros((w, h), dtype=np.uint8)
        cv2.fillPoly(mask, [mouth], 255)
        kernel = np.ones((mouth_mask_dilatation, mouth_mask_dilatation), np.uint8)
        dilated_mask = cv2.dilate(mask, kernel, iterations=1)
        contours, _ = cv2.findContours(dilated_mask, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)
        dilated_points = contours[0].squeeze()
        return dilated_points

    def draw_mask(self, img, target_faces, faces_properties):
        (mstart, mend) = face_utils.FACIAL_LANDMARKS_IDXS["mouth"]
        (jstart, jend) = face_utils.FACIAL_LANDMARKS_IDXS["jaw"]
        (nstart, nend) = face_utils.FACIAL_LANDMARKS_IDXS["nose"]

        original_gray = cv2.cvtColor(img, cv2.COLOR_RGB2GRAY)

        for (i, rect) in enumerate(target_faces):
            if not self.only_mouth:
                jaw = rect.landmark_3d_68[jstart:jend][1:-1]
                jaw = [[int(sublist[0]), int(sublist[1])] for sublist in jaw]
                nose = rect.landmark_3d_68[nstart:nend][2][:2]
                nose = [int(nose[0]), int(nose[1])]
            mouth = rect.landmark_3d_68[mstart:mend][:-8]
            mouth = [[int(sublist[0]), int(sublist[1])] for sublist in mouth]
            mouth = np.delete(mouth, [3], axis=0)

            if self.mouth_mask_dilatation > 0:
                mouth_mask_dilatation = self.mouth_mask_dilatation
                if faces_properties:
                    mouth_mask_dilatation = faces_properties[i]["mouth_mask_dilatation"]

                mouth = self.dilate_mouth(mouth, original_gray.shape[0], original_gray.shape[1], mouth_mask_dilatation)

            if not self.only_mouth:
                mask = np.zeros_like(original_gray)
                external_shape = np.append(jaw, [nose], axis=0)
                hull = ConvexHull(external_shape)
                hull_points = external_shape[hull.vertices]
                external_shape_pts = hull_points.reshape((-1, 1, 2))
                mask = cv2.fillPoly(mask, [external_shape_pts], 255)
                if self.erode_face_mask > 0:
                    erode_face_mask = self.erode_face_mask
                    if faces_properties:
                        erode_face_mask = faces_properties[i]["erode_face_mask"]
                    kernel = np.ones((erode_face_mask, erode_face_mask), np.uint8)
                    mask = cv2.erode(mask, kernel, iterations=1)

                mask_blur = self.mask_blur
                if faces_properties:
                    mask_blur = faces_properties[i]["mask_blur"]
                masked_save = self.apply_blur(mask, mask_blur)
                img = self.apply_mask(img, masked_save, (0, 255, 255))

            mask = np.zeros_like(original_gray)
            external_shape = mouth
            external_shape_pts = external_shape.reshape((-1, 1, 2))
            mask = cv2.fillPoly(mask, [external_shape_pts], 255)
            mask_blur = self.mask_blur
            if faces_properties:
                mask_blur = faces_properties[i]["mask_blur"]
            masked_save = self.apply_blur(mask, mask_blur)
            img = self.apply_mask(img, masked_save, (0, 0, 255))

        return img

    @staticmethod
    def apply_mask(img, mask, color):
        extended_mask = np.stack([mask] * 3, axis=-1)
        normalized_mask = extended_mask / 255.0
        color_overlay = np.full(img.shape, color, dtype=np.uint8)  # RGB for yellow
        color_overlay = color_overlay * normalized_mask
        dst = color_overlay * normalized_mask
        original = img * (1 - normalized_mask) + dst
        original = original.astype(np.uint8)
        original = cv2.addWeighted(img, 1 - 0.5, original, 0.5, 0)

        return original

    @staticmethod
    def apply_blur(mask, mask_blur):
        if mask_blur > 0:
            blur = mask_blur + (1 - mask_blur % 2)  # Ensure blur size is an odd number
            return cv2.GaussianBlur(mask, (blur, blur), 0)
        else:
            return mask

    def append_new_frame(self, frame_number, face_count, target_faces):
        new_keyframe = {"frame": str(frame_number + 1), "faces": face_count}
        if face_count > 0:
            new_keyframe["target_face"] = target_faces
        self.frames[str(frame_number + 1)] = new_keyframe

    def append_new_keyframe(self, frame_number, face_count):
        new_keyframe = {"frame": str(frame_number + 1),
                        "faces": face_count}
        faces_properties = []
        if face_count > 0:
            for i in range(face_count):
                property = {"id": str(i),
                            "padding": self.pad,
                            "mouth_mask_dilatation": self.mouth_mask_dilatation,
                            "erode_face_mask": self.erode_face_mask,
                            "mask_blur": self.mask_blur,
                            "speaker": True if i == 0 else False
                            }

                if self.source_faces:
                    property["faceswap"] = len(self.source_faces)
                    # property["source_face"] = self.source_faces
                    property["faceswap_choice"] = str(i) if i < len(self.source_faces) else "0"
                faces_properties.append(property)
        new_keyframe["faces_properties"] = faces_properties
        self.keyframes.append(new_keyframe)

    def update_audio_scene_keyframes(self, frame_number, nb_face):
        keyframe = [keyframe for keyframe in self.keyframes if int(keyframe["frame"]) == frame_number]
        if not keyframe:
            # find previous keyframe
            last_keyframes = [keyframe for keyframe in self.keyframes if int(keyframe["frame"]) < frame_number]
            if last_keyframes:
                new_keyframe = deepcopy(last_keyframes[-1])
                new_keyframe["faces_properties"] = new_keyframe["faces_properties"][0:nb_face]
                new_keyframe["faces"] = nb_face
                new_keyframe["frame"] = str(frame_number)
                self.keyframes.append(new_keyframe)

        self.keyframes = sorted(self.keyframes, key=lambda k: int(k["frame"]))

    def remove_blank_keyframes(self, speakers, fps):
        keyframes = []
        # get keyframe when no speaker is talking
        intervalles = [
            {"start": int(fps * speakers[i]["end"]), "end": int(fps * speakers[i + 1]["start"])}
            for i in range(len(speakers) - 1)
        ]
        # remove keyframe when no speaker is not talking
        for keyframe in self.keyframes:
            if int(keyframe["frame"]) > 0:
                if not any(
                        [
                            intervalle["start"] < int(keyframe["frame"]) < intervalle["end"]
                            for intervalle in intervalles
                        ]
                ):
                    keyframes.append(keyframe)
            else:
                keyframes.append(keyframe)

        self.keyframes = keyframes

    def find_faces(self, target_img: Image.Image, frame_number: int, update_keyframe: bool = True,
                   faces_properties: dict = None, face_only: bool = False) -> str:
        # current_frame = [keyframe for keyframe in self.frames if keyframe["frame"] == str(frame_number + 1)]
        #frame number as format "00000"

        current_frame = self.frames.get(str(frame_number + 1))
        f_number = str(frame_number).rjust(5, '0')
        target_img_cv = cv2.cvtColor(np.array(target_img), cv2.COLOR_RGB2BGR)
        if not current_frame:
            save_path = f"{self.analyse_folder}/frame_{f_number}.png"
            cv2.imwrite(save_path, target_img_cv)
            target_faces = self.get_all_face(target_img_cv)
        else:
            target_faces = current_frame.get("target_face", [])

        if not face_only:
            self.draw_faces(target_img_cv, target_faces, faces_properties, face_only)
        face_count = len(target_faces)
        target_img_cv = self.draw_mask(target_img_cv, target_faces, faces_properties)
        if update_keyframe:
            self.update_keyframes(frame_number, face_count, target_faces)

        if face_only:
            speaker = [idx for idx, face in enumerate(faces_properties) if face["speaker"]]
            if speaker:
                speaker_face = target_faces[speaker[0]]
                pady1, pady2, padx1, padx2 = faces_properties[speaker[0]]["padding"]
                target_img_cv = target_img_cv[int(speaker_face.bbox[1] - pady1):int(speaker_face.bbox[3] + pady2), int(speaker_face.bbox[0] - padx1):int(speaker_face.bbox[2] + padx2)]
        save_path = f"{self.analyse_folder}/all_face_{frame_number}.png"
        cv2.imwrite(save_path, target_img_cv)

        return save_path

    def update_keyframes(self, frame_number, face_count, target_faces):
        if not self.keyframes or self.frames.get(str(frame_number))["faces"] != face_count:
            if len(self.keyframes) > 1 and self.frames.get(str(frame_number - 1))["faces"] == face_count:
                if self.keyframes[-1]["frame"] == str(frame_number):
                    self.keyframes.pop()
                elif face_count > 0:
                    self.append_new_keyframe(frame_number, face_count)
            else:
                if face_count > 0:
                    self.append_new_keyframe(frame_number, face_count)
        self.append_new_frame(frame_number, face_count, target_faces)

    def update_frame(self, frame_number: int, faces_properties: dict, face_only: bool = False) -> str:
        frame_number = int(frame_number) - 1
        f_number = str(frame_number).rjust(5, '0')
        frame = cv2.imread(f"{self.analyse_folder}/frame_{f_number}.png")
        frame = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)

        if faces_properties:
            return self.find_faces(frame, frame_number, False, faces_properties, face_only)
        return f"{self.analyse_folder}/all_face_{frame_number}.png"

    def get_faceswap_faces(self):
        self.create_project()
        self.init_models()
        output_img_swap = os.path.join(self.faceswap_video_folder, "faceswap.png")
        shutil.copyfile(self.face_swap, output_img_swap)
        if self.face_swap is not None:
            self.source_faces = self.get_all_face(self.face_swap)
            return self.source_faces, output_img_swap
        else:
            self.face_swap = None
            self.source_faces = []
            return [], None

    def find_speaker_change(self, video, fps):
        self.logger.info("{0}{1}", 'Find speaker change for video ', video)
        video_util = Video()
        audio_path = video_util.extract_audio(self.project_name, video)
        speaker_time = []
        if audio_path is not None:
            with suppress_stdout():
                pipeline = Pipeline.from_pretrained("pyannote/speaker-diarization-3.1",
                                                    use_auth_token=self.huggingface_token)
                pipeline.to(torch.device("cuda"))
                diarization = pipeline(audio_path)
            speaker_change = []
            last_speaker = None
            for turn, what, speaker in diarization.itertracks(yield_label=True):
                new_speaker = {
                    "start": turn.start,
                    "end": turn.end,
                    "speaker": speaker
                }
                if last_speaker != speaker:
                    speaker_change.append(new_speaker)
                    last_speaker = speaker
                speaker_time.append(new_speaker)

            for speaker in speaker_change:
                frame_number = int(fps * speaker["start"])
                if self.frames.get(str(frame_number + 1)):
                    if self.frames.get(str(frame_number + 1))["faces"] > 0:
                        self.logger.info("{0}{1}", 'Speaker change for frame ', frame_number + 1)
                        self.update_audio_scene_keyframes(frame_number + 1, self.frames.get(str(frame_number + 1))["faces"])

            pipeline.to(torch.device("cpu"))
            del pipeline
            gc.collect()
            torch.cuda.empty_cache()
        return speaker_time

    def change_scene_detector(self, video, fps):
        self.logger.info("{0}{1}", 'Find scene change for video ', video)
        scene_list = detect(video, ContentDetector())
        for scene in scene_list:
            frame_number = scene[0].get_frames()
            if self.frames.get(str(frame_number + 1)):
                if self.frames.get(str(frame_number + 1))["faces"] > 0:
                    self.logger.info("{0}{1}", 'Scene change for frame ', frame_number + 1)
                    self.update_audio_scene_keyframes(frame_number + 1, self.frames.get(str(frame_number + 1))["faces"])

    def execute(self, video_properties):
        self.logger.info("{0}{1}", 'Start analyse video ', self.video)
        #self.logger.debug("{0}\n{1}", 'Video properties ', video_properties)
        self.create_project()
        # extract frame from video
        self.keyframes = []
        self.frames = {}
        self.init_models()
        self.source_faces = video_properties.get("source_faces", None)

        video_stream = cv2.VideoCapture(self.video)
        frame_count = int(video_stream.get(cv2.CAP_PROP_FRAME_COUNT))

        frame_number = 0
        full_frames = []
        fps = video_stream.get(cv2.CAP_PROP_FPS)
        shape = None
        self.logger.info("{0}{1}", 'Extract frame from video ', "")
        while 1:
            print("[INFO] Processing frame: " + str(frame_number) + "/" + str(frame_count), end="\r")
            still_reading, frame = video_stream.read()

            if not still_reading:
                video_stream.release()
                break
            if self.resize_factor > 1:
                frame = cv2.resize(frame,
                                   (frame.shape[1] // self.resize_factor, frame.shape[0] // self.resize_factor))
            if shape is None:
                shape = frame.shape
            frame = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)
            full_frames.append(self.find_faces(frame, frame_number))
            #all_frames.append((frame, frame_number))
            frame_number += 1

        video_properties["project_name"] = self.project_name
        #video_properties["faceswap_video"] = None
        #video_properties["wav2lip_video"] = None

        video_path = os.path.join(self.input_video, "video.mp4")
        if "gradio" in self.video:
            shutil.copyfile(self.video, video_path)
        video_properties["video_path"] = video_path
        video_properties["fps"] = fps
        video_properties["nb_frames"] = len(full_frames)
        if self.keyframes_on_speakers:
            self.find_speaker_change(video_path, fps)

        if self.keyframes_on_scenes:
            self.change_scene_detector(video_path, fps)

        self.save(full_frames, video_properties)
        #self.logger.debug("{0}\n{1}", 'Video properties ', video_properties)
        return full_frames, len(full_frames), self.keyframes, self.frames, video_properties

    def save_keyframes(self, keyframes):
        self.keyframes = keyframes
        with open(f"{self.project_folder}/keyframes.json", "w") as f:
            json.dump(self.keyframes, f, indent=4)

    def save_project_properties(self, project_properties):
        new_target = {**project_properties}
        if "source_faces" in project_properties and len(project_properties["source_faces"]) > 0:
            targets = self.convert_to_json(project_properties["source_faces"])
            new_target["source_faces"] = targets
        with open(f"{self.project_folder}/project.json", "w") as f:
            json.dump(new_target, f, indent=4)

    def save(self, full_frames, video_properties):
        self.logger.info("{0}{1}", 'Save project ', self.project_name)
        with open(f"{self.project_folder}/keyframes.json", "w") as f:
            json.dump(self.keyframes, f, indent=4)
        with open(f"{self.project_folder}/full_frames.json", "w") as f:
            json.dump(full_frames, f, indent=4)

        self.save_project_properties(video_properties)

        frames = {}
        for x, frame in enumerate(self.frames.keys()):
            new_frame = {"frame": self.frames[frame]["frame"], "faces": self.frames[frame]["faces"]}
            if "target_face" in self.frames[frame]:
                new_frame["target_face"] = self.convert_to_json(self.frames[frame]["target_face"])
            frames[frame] = new_frame

        with open(f"{self.project_folder}/frames.json", "w") as f:
            json.dump(frames, f, indent=4)

    def load(self):
        self.logger.info("{0}{1}", 'Load project ', self.project_name)
        full_frames = []
        project_properties = {}
        if os.path.exists(self.project_folder):


            if os.path.exists(f"{self.project_folder}/keyframes.json"):
                with open(f"{self.project_folder}/keyframes.json", "r") as f:
                    self.keyframes = json.load(f)
            if os.path.exists(f"{self.project_folder}/full_frames.json"):
                with open(f"{self.project_folder}/full_frames.json", "r") as f:
                    full_frames = json.load(f)
            if os.path.exists(f"{self.project_folder}/frames.json"):
                with open(f"{self.project_folder}/frames.json", "r") as f:
                    self.frames = json.load(f)
            if os.path.exists(f"{self.project_folder}/project.json"):
                with open(f"{self.project_folder}/project.json", "r") as f:
                    project_properties = json.load(f)

            if "source_faces" in project_properties:
                targets = self.convert_to_object(project_properties["source_faces"])
                project_properties["source_faces"] = targets

            frames = {}
            for x, frame in enumerate(self.frames.keys()):
                new_frame = {"frame": self.frames[frame]["frame"], "faces": self.frames[frame]["faces"]}
                if "target_face" in self.frames[frame]:
                    new_frame["target_face"] = self.convert_to_object(self.frames[frame]["target_face"])
                frames[frame] = new_frame
            self.frames = frames
        return full_frames, len(full_frames), self.keyframes, self.frames, project_properties

    @staticmethod
    def convert_to_object(faces):
        targets = []
        for i, target in enumerate(faces):
            new_target = {}
            new_target["bbox"] = np.array(target["bbox"]).astype(np.float64)
            new_target["center"] = target["center"]
            new_target["angle"] = np.float64(target["angle"])
            new_target["det_score"] = np.float32(target["det_score"])
            new_target["embedding"] = np.array(target["embedding"]).astype(np.float32)
            new_target["embedding_norm"] = np.float32(target["embedding_norm"])
            new_target["gender"] = np.int64(target["gender"])
            new_target["kps"] = np.array(target["kps"]).astype(np.float32)
            new_target["landmark_2d_106"] = np.array(target["landmark_2d_106"]).astype(np.float32)
            new_target["landmark_3d_68"] = np.array(target["landmark_3d_68"]).astype(np.float32)
            # print("normed_embeddings")
            # new_target["normed_embeddings"] = target.normed_embeddings.tolist()
            new_target["pose"] = np.array(target["pose"]).astype(np.float32)
            new_target["sex"] = target["sex"]

            targets.append(SimpleNamespace(**new_target))
        return targets

    @staticmethod
    def convert_to_json(faces):
        targets = []
        for i, target in enumerate(faces):
            new_target = {}
            new_target["bbox"] = target.bbox.tolist()
            new_target["center"] = target.center
            new_target["angle"] = float(target.angle)
            new_target["det_score"] = float(target.det_score)
            new_target["embedding"] = target.embedding.tolist()
            new_target["embedding_norm"] = float(target.embedding_norm)
            new_target["gender"] = int(target.gender)
            new_target["kps"] = target.kps.tolist()
            new_target["landmark_2d_106"] = target.landmark_2d_106.tolist()
            new_target["landmark_3d_68"] = target.landmark_3d_68.tolist()
            # print("normed_embeddings")
            # new_target["normed_embeddings"] = target.normed_embeddings.tolist()
            new_target["pose"] = target.pose.tolist()
            new_target["sex"] = target.sex
            targets.append(new_target)
        return targets
